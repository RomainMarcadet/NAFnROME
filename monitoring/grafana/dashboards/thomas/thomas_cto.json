    {
      "id": 5,
      "title": "Score confiance top-1 — dérive modèle",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "search_score_top1",
          "legendFormat": "Score top-1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.40 },
              { "color": "green", "value": 0.60 }
            ]
          },
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "thresholdsStyle": { "mode": "line" }
      }
    },

